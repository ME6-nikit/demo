PORT=3000
NODE_ENV=development

# MySQL 8.0 connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=oma
DB_CONNECTION_LIMIT=10

# Shopify webhook HMAC secret.
# Leave as the placeholder value below to skip signature validation during
# local development. In production, replace with the real secret from the
# Shopify partner dashboard.
SHOPIFY_WEBHOOK_SECRET=replace-with-shopify-webhook-secret

# Directory where department PDFs are stored
PDF_STORAGE_DIR=storage/pdfs

# Comma-separated departments required for "designer cake" orders
DESIGNER_CAKE_DEPARTMENTS=DESIGN,CONFECTIONERY

# Automatically create print jobs after PDF generation (requires printer
# assignments). Set to false when testing webhook + PDF only.
AUTO_TRIGGER_PRINT_JOBS=false

# Run database migrations on server startup
RUN_MIGRATIONS_ON_BOOT=true
