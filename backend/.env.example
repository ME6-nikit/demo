PORT=3000
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=oma
DB_CONNECTION_LIMIT=10
# Set to "test-webhook-secret" for local dev (bypasses HMAC validation).
# In production, replace with the real Shopify webhook secret.
SHOPIFY_WEBHOOK_SECRET=test-webhook-secret
PDF_STORAGE_DIR=storage/pdfs
DESIGNER_CAKE_DEPARTMENTS=DESIGN,CONFECTIONERY
AUTO_TRIGGER_PRINT_JOBS=false
RUN_MIGRATIONS_ON_BOOT=true
